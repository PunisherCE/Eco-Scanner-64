            <ui:Button text="About" name="About" class="ButtonsMenu" />
        </ui:VisualElement>
        <ui:VisualElement name="JustAView" style="flex-grow: 1; width: 70%; height: 100%;" />
    </ui:VisualElement>
</ui:UXML>
